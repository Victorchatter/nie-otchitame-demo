{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://nie-otchitame-api.example.com/api/:path*"
    },
    {
      "source": "/health",
      "destination": "https://nie-otchitame-api.example.com/health"
    }
  ]
}
